{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Medicare Mental Health Patients by Provider Type (2014-2024)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff"
  },
  "width": 620,
  "height": 320,
  "background": "transparent",
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/medicare_provider_trend.csv"
  },
  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 2
  },
  "encoding": {
    "x": {
      "field": "FinancialYear",
      "type": "ordinal",
      "title": "Financial Year",
      "axis": {
        "labelAngle": -45,
        "labelColor": "#c5cfe0",
        "titleColor": "#c5cfe0",
        "gridColor": "#4a6080",
        "tickColor": "#4a6080",
        "domainColor": "#4a6080",
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      }
    },
    "y": {
      "field": "patients",
      "type": "quantitative",
      "title": "Number of Patients",
      "axis": {
        "format": "~s",
        "labelColor": "#c5cfe0",
        "titleColor": "#c5cfe0",
        "gridColor": "#4a6080",
        "tickColor": "#4a6080",
        "domainColor": "#4a6080",
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      }
    },
    "color": {
      "field": "ProviderType",
      "type": "nominal",
      "title": "Provider Type",
      "scale": {
        "domain": [
          "General practitioners",
          "Other psychologists",
          "Clinical psychologists",
          "Psychiatrists",
          "Other allied health providers"
        ],
        "range": [
          "#d1e5f0",
          "#92c5de",
          "#4393c3",
          "#2166ac",
          "#053061"
        ]
      },
      "legend": {
        "labelColor": "#c5cfe0",
        "titleColor": "#c5cfe0",
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      }
    },
    "tooltip": [
      {
        "field": "FinancialYear",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "ProviderType",
        "type": "nominal",
        "title": "Provider"
      },
      {
        "field": "patients",
        "type": "quantitative",
        "title": "Patients",
        "format": ","
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {
      "color": "#ffffff",
      "font": "Times New Roman"
    }
  }
}