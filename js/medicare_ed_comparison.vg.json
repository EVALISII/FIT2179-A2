{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Medicare Patients vs Emergency Department Presentations (2014-2024)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff"
  },
  "width": 650,
  "height": 340,
  "background": "transparent",
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/medicare_vs_ed_trend.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "color": "#2166ac",
        "strokeWidth": 2.5,
        "point": {"color": "#2166ac", "filled": true}
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Financial Year",
          "axis": {
            "labelAngle": -45,
            "labelColor": "#c5cfe0",
            "titleColor": "#c5cfe0",
            "gridColor": "#4a6080",
            "tickColor": "#4a6080",
            "domainColor": "#4a6080",
            "labelFont": "Times New Roman",
            "titleFont": "Times New Roman"
          }
        },
        "y": {
          "field": "total_patients",
          "type": "quantitative",
          "title": "Medicare Mental Health Patients",
          "axis": {
            "titleColor": "#2166ac",
            "format": "~s",
            "labelColor": "#c5cfe0",
            "gridColor": "#4a6080",
            "tickColor": "#4a6080",
            "domainColor": "#4a6080",
            "labelFont": "Times New Roman",
            "titleFont": "Times New Roman"
          }
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "total_patients", "type": "quantitative", "title": "Medicare Patients", "format": ","},
          {"field": "ed_presentations", "type": "quantitative", "title": "ED Presentations", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#d6604d",
        "strokeWidth": 2.5,
        "strokeDash": [6, 3],
        "point": {"color": "#d6604d", "filled": true}
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {
          "field": "ed_presentations",
          "type": "quantitative",
          "title": "ED Mental Health Presentations",
          "axis": {
            "titleColor": "#d6604d",
            "format": "~s",
            "labelColor": "#c5cfe0",
            "gridColor": "#4a6080",
            "tickColor": "#4a6080",
            "domainColor": "#4a6080",
            "labelFont": "Times New Roman",
            "titleFont": "Times New Roman"
          }
        }
      }
    }
  ],
  "resolve": {"scale": {"y": "independent"}},
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {
      "color": "#ffffff",
      "font": "Times New Roman"
    }
  }
}