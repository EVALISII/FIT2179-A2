{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Mental Health Expenditure by Funding Source (2014-2024, $million)",
    "fontSize": 14,
    "fontWeight": "bold",
    "anchor": "middle"
  },
  "width": 600,
  "height": 300,
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/expenditure_funding.csv"
  },
  "mark": {
    "type": "area"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Financial Year",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "expenditure_million",
      "type": "quantitative",
      "title": "Expenditure ($million)",
      "axis": {
        "format": "~s"
      }
    },
    "color": {
      "field": "funding_source",
      "type": "nominal",
      "title": "Funding Source",
      "scale": {
        "domain": [
          "State and territory governments",
          "Australian Government",
          "Private health and other third party insurers"
        ],
        "range": [
          "#2166ac",
          "#4dac26",
          "#d6604d"
        ]
      }
    },
    "tooltip": [
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "funding_source",
        "type": "nominal",
        "title": "Funding Source"
      },
      {
        "field": "expenditure_million",
        "type": "quantitative",
        "title": "Expenditure ($M)",
        "format": ",.0f"
      }
    ]
  }
}