{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Medicare Mental Health Patients per 1,000 Population by State (2023-24)",
    "fontSize": 14,
    "fontWeight": "bold",
    "anchor": "middle"
  },
  "width": 750,
  "height": 450,
  "projection": {"type": "equirectangular"},
  "layer": [
    {
      "data": {
        "url": "data/medicare_by_state.csv",
        "format": {
          "type": "topojson",
          "feature": "ne_50m_admin_1_states_provinces"
        }
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {"url": "data/medicare_by_state.csv"},
            "key": "state",
            "fields": ["patient_rate_per_1000", "total_patients"]
          }
        }
      ],
      "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "color": {
          "field": "patient_rate_per_1000",
          "type": "quantitative",
          "scale": {"scheme": "blues"},
          "legend": {"title": "Patients per 1,000 population"}
        },
        "tooltip": [
          {"field": "properties.name", "type": "nominal", "title": "State"},
          {"field": "patient_rate_per_1000", "type": "quantitative", "title": "Rate per 1,000"},
          {"field": "total_patients", "type": "quantitative", "title": "Total patients", "format": ","}
        ]
      }
    }
  ]
}