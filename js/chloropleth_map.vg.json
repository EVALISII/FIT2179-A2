{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Medicare Mental Health Patients per 1,000 Population by State (2023-24)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff"
  },
  "width": 750,
  "height": 450,
  "projection": {
    "type": "equirectangular"
  },
  "layer": [
    {
      "data": {
        "url": "https://evalisii.github.io/FIT2179-A2/js/ne_50m_admin_1_states_provinces.json",
        "format": {
          "type": "topojson",
          "feature": "ne_50m_admin_1_states_provinces"
        }
      },
      "transform": [
        {
          "lookup": "properties.gn_name",
          "from": {
            "data": {
              "url": "https://evalisii.github.io/FIT2179-A2/data/medicare_by_state.csv"
            },
            "key": "state",
            "fields": [
              "patient_rate_per_1000",
              "total_patients"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "color": {
          "field": "patient_rate_per_1000",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [
              70,
              85,
              95,
              105
            ],
            "range": [
              "#d1e5f0",
              "#92c5de",
              "#4393c3",
              "#2166ac",
              "#053061"
            ]
          },
          "legend": {
            "title": "Patients per 1,000",
            "titleFont": "Times New Roman",
            "labelFont": "Times New Roman"
          }
        },
        "tooltip": [
          {
            "field": "properties.gn_name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "patient_rate_per_1000",
            "type": "quantitative",
            "title": "Rate per 1,000"
          },
          {
            "field": "total_patients",
            "type": "quantitative",
            "title": "Total Patients",
            "format": ","
          }
        ]
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {
      "color": "#ffffff",
      "font": "Times New Roman"
    }
  },
  "background": "transparent"
}