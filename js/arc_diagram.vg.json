{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Community Mental Health Contacts: Age Group to Diagnosis (2023-24)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff"
  },
  "background": "transparent",
  "width": 600,
  "height": 350,
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/network_age_diagnosis.csv"
  },
  "mark": {"type": "rect", "cornerRadiusEnd": 2},
  "encoding": {
    "x": {
      "field": "source",
      "type": "ordinal",
      "title": "Age Group",
      "sort": ["0-11","12-17","18-24","25-34","35-44","45-54","55-64","65+"],
      "axis": {
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman",
        "labelColor": "#c5cfe0",
        "titleColor": "#c5cfe0",
        "domainColor": "#4a6080",
        "tickColor": "#4a6080"
      }
    },
    "y": {
      "field": "target",
      "type": "ordinal",
      "title": "Principal Diagnosis",
      "sort": ["Schizophrenia & psychosis","Mood disorders","Anxiety & stress","Personality disorders","Substance use"],
      "axis": {
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman",
        "labelColor": "#c5cfe0",
        "titleColor": "#c5cfe0",
        "domainColor": "#4a6080",
        "tickColor": "#4a6080"
      }
    },
    "color": {
      "field": "contacts",
      "type": "quantitative",
      "title": "Number of Contacts",
      "scale": {
        "type": "threshold",
        "domain": [50000, 150000, 300000, 500000],
        "range": ["#d1e5f0", "#92c5de", "#4393c3", "#2166ac", "#053061"]
      },
      "legend": {
        "titleFont": "Times New Roman",
        "labelFont": "Times New Roman",
        "titleColor": "#c5cfe0",
        "labelColor": "#c5cfe0"
      }
    },
    "tooltip": [
      {"field": "source", "type": "ordinal", "title": "Age Group"},
      {"field": "target", "type": "ordinal", "title": "Diagnosis"},
      {"field": "contacts", "type": "quantitative", "title": "Contacts", "format": ","}
    ]
  },
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {"color": "#ffffff", "font": "Times New Roman"}
  }
}