{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Mental Health Expenditure by Funding Source (2014-2024)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff"
  },
  "width": 620,
  "height": 300,
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/expenditure_funding.csv"
  },
  "mark": {
    "type": "area"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Financial Year",
      "axis": {
        "labelAngle": -45,
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      }
    },
    "y": {
      "field": "expenditure_million",
      "type": "quantitative",
      "title": "Expenditure ($million)",
      "axis": {
        "format": "~s",
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      }
    },
    "color": {
      "field": "funding_source",
      "type": "nominal",
      "title": "Funding Source",
      "scale": {
        "domain": [
          "State and territory governments",
          "Australian Government",
          "Private health and other third party insurers"
        ],
        "range": [
          "#2166ac",
          "#4393c3",
          "#92c5de"
        ]
      },
      "legend": {
        "titleFont": "Times New Roman",
        "labelFont": "Times New Roman"
      }
    },
    "tooltip": [
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "funding_source",
        "type": "nominal",
        "title": "Funding Source"
      },
      {
        "field": "expenditure_million",
        "type": "quantitative",
        "title": "Expenditure ($M)",
        "format": ",.0f"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {
      "color": "#ffffff",
      "font": "Times New Roman"
    }
  },
  "background": "transparent"
}