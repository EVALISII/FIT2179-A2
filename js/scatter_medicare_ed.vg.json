{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Medicare Access vs Emergency Department Presentations by State (2023-24)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff",
    "subtitle": "Each point represents a state or territory. NT is an extreme outlier \u2014 low Medicare access, highest ED rate.",
    "subtitleColor": "#c5cfe0",
    "subtitleFont": "Times New Roman",
    "subtitleFontSize": 11
  },
  "width": 550,
  "height": 380,
  "background": "transparent",
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/scatter_medicare_ed.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 120
      },
      "encoding": {
        "x": {
          "field": "patient_rate_per_1000",
          "type": "quantitative",
          "title": "Medicare Mental Health Patients per 1,000",
          "axis": {
            "labelColor": "#c5cfe0",
            "titleColor": "#c5cfe0",
            "gridColor": "#4a6080",
            "tickColor": "#4a6080",
            "domainColor": "#4a6080",
            "labelFont": "Times New Roman",
            "titleFont": "Times New Roman",
            "tickCount": 6
          },
          "scale": {
            "domain": [
              40,
              115
            ]
          }
        },
        "y": {
          "field": "ed_rate_per_1000",
          "type": "quantitative",
          "title": "ED Mental Health Presentations per 1,000",
          "axis": {
            "labelColor": "#c5cfe0",
            "titleColor": "#c5cfe0",
            "gridColor": "#4a6080",
            "tickColor": "#4a6080",
            "domainColor": "#4a6080",
            "labelFont": "Times New Roman",
            "titleFont": "Times New Roman",
            "tickCount": 6
          },
          "scale": {
            "domain": [
              4,
              30
            ]
          }
        },
        "color": {
          "field": "ed_rate_per_1000",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [
              9,
              12,
              15,
              20
            ],
            "range": [
              "#d1e5f0",
              "#92c5de",
              "#4393c3",
              "#2166ac",
              "#053061"
            ]
          },
          "legend": {
            "title": "ED Rate per 1,000",
            "labelFont": "Times New Roman",
            "titleFont": "Times New Roman",
            "labelColor": "#c5cfe0",
            "titleColor": "#c5cfe0"
          }
        },
        "tooltip": [
          {
            "field": "state_abbrev",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "patient_rate_per_1000",
            "type": "quantitative",
            "title": "Medicare Rate per 1,000"
          },
          {
            "field": "ed_rate_per_1000",
            "type": "quantitative",
            "title": "ED Rate per 1,000"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -12,
        "font": "Times New Roman",
        "fontSize": 11,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "patient_rate_per_1000",
          "type": "quantitative",
          "scale": {
            "domain": [
              40,
              115
            ]
          },
          "axis": {
            "labelColor": "#c5cfe0",
            "titleColor": "#c5cfe0",
            "gridColor": "#4a6080",
            "tickColor": "#4a6080",
            "domainColor": "#4a6080",
            "labelFont": "Times New Roman",
            "titleFont": "Times New Roman",
            "tickCount": 6
          }
        },
        "y": {
          "field": "ed_rate_per_1000",
          "type": "quantitative",
          "scale": {
            "domain": [
              4,
              30
            ]
          },
          "axis": {
            "labelColor": "#c5cfe0",
            "titleColor": "#c5cfe0",
            "gridColor": "#4a6080",
            "tickColor": "#4a6080",
            "domainColor": "#4a6080",
            "labelFont": "Times New Roman",
            "titleFont": "Times New Roman",
            "tickCount": 6
          }
        },
        "text": {
          "field": "state_abbrev",
          "type": "nominal"
        },
        "color": {
          "value": "#c5cfe0"
        }
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {
      "color": "#ffffff",
      "font": "Times New Roman"
    }
  }
}