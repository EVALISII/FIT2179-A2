{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Mental Health ED Presentations by Diagnosis Type (2023-24)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff"
  },
  "width": 500,
  "height": 280,
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/ed_diagnosis_2023_24.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3,
    "color": "#2166ac"
  },
  "encoding": {
    "y": {
      "field": "diagnosis",
      "type": "ordinal",
      "title": null,
      "sort": "-x",
      "axis": {
        "labelFont": "Times New Roman"
      }
    },
    "x": {
      "field": "presentations_2023_24",
      "type": "quantitative",
      "title": "Number of Presentations",
      "axis": {
        "format": "~s",
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      }
    },
    "tooltip": [
      {
        "field": "diagnosis",
        "type": "nominal",
        "title": "Diagnosis"
      },
      {
        "field": "presentations_2023_24",
        "type": "quantitative",
        "title": "Presentations",
        "format": ","
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {
      "color": "#ffffff",
      "font": "Times New Roman"
    }
  },
  "background": "transparent"
}