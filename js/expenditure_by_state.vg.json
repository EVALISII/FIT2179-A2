{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "State & Territory Mental Health Expenditure (2023-24, $million)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff",
    "subtitle": "Victoria leads spending despite NSW having more patients. NT spends the least.",
    "subtitleColor": "#c5cfe0",
    "subtitleFont": "Times New Roman",
    "subtitleFontSize": 11
  },
  "width": 580,
  "height": 300,
  "background": "transparent",
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/treemap_expenditure_state.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "state",
      "type": "ordinal",
      "sort": "-x",
      "title": null,
      "axis": {
        "labelColor": "#c5cfe0",
        "titleColor": "#c5cfe0",
        "gridColor": "#4a6080",
        "tickColor": "#4a6080",
        "domainColor": "#4a6080",
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman",
        "labelFontSize": 12
      }
    },
    "x": {
      "field": "expenditure_million",
      "type": "quantitative",
      "title": "Expenditure ($million)",
      "axis": {
        "labelColor": "#c5cfe0",
        "titleColor": "#c5cfe0",
        "gridColor": "#4a6080",
        "tickColor": "#4a6080",
        "domainColor": "#4a6080",
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      }
    },
    "color": {
      "field": "expenditure_million",
      "type": "quantitative",
      "scale": {
        "type": "threshold",
        "domain": [
          200,
          500,
          1000,
          2000
        ],
        "range": [
          "#d1e5f0",
          "#92c5de",
          "#4393c3",
          "#2166ac",
          "#053061"
        ]
      },
      "legend": {
        "title": "$million",
        "titleFont": "Times New Roman",
        "labelFont": "Times New Roman",
        "titleColor": "#c5cfe0",
        "labelColor": "#c5cfe0"
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "expenditure_million",
        "type": "quantitative",
        "title": "Expenditure ($M)",
        "format": ",.1f"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {
      "color": "#ffffff",
      "font": "Times New Roman"
    }
  }
}