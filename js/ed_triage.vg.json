{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Mental Health Emergency Department Presentations by Urgency (2014-2024)",
    "fontSize": 15,
    "fontWeight": "bold",
    "font": "Times New Roman",
    "anchor": "middle",
    "color": "#ffffff"
  },
  "width": 650,
  "height": 320,
  "data": {
    "url": "https://evalisii.github.io/FIT2179-A2/data/ed_triage_trend.csv"
  },
  "mark": {
    "type": "area"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Financial Year",
      "axis": {
        "labelAngle": -45,
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      }
    },
    "y": {
      "field": "presentations",
      "type": "quantitative",
      "title": "Number of Presentations",
      "axis": {
        "format": "~s",
        "labelFont": "Times New Roman",
        "titleFont": "Times New Roman"
      },
      "stack": "normalize"
    },
    "color": {
      "field": "triage_category",
      "type": "nominal",
      "title": "Triage Category",
      "scale": {
        "domain": [
          "Resuscitation",
          "Emergency",
          "Urgent",
          "Semi-urgent",
          "Non-urgent"
        ],
        "range": [
          "#053061",
          "#2166ac",
          "#4393c3",
          "#92c5de",
          "#d1e5f0"
        ]
      },
      "legend": {
        "titleFont": "Times New Roman",
        "labelFont": "Times New Roman"
      }
    },
    "tooltip": [
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "triage_category",
        "type": "nominal",
        "title": "Triage"
      },
      {
        "field": "presentations",
        "type": "quantitative",
        "title": "Presentations",
        "format": ","
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "gridColor": "#4a6080",
      "tickColor": "#4a6080",
      "domainColor": "#4a6080",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "legend": {
      "labelColor": "#c5cfe0",
      "titleColor": "#c5cfe0",
      "labelFont": "Times New Roman",
      "titleFont": "Times New Roman"
    },
    "title": {
      "color": "#ffffff",
      "font": "Times New Roman"
    }
  },
  "background": "transparent"
}